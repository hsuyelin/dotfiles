# Secrets - API keys, tokens, passwords
secrets/

# Private - Personal/company information, machine-specific paths
private/

# Docker / OrbStack runtime state
docker/.token_seed
docker/.token_seed.lock
docker/buildx/
docker/cli-plugins/
docker/config.json
docker/contexts/

# Zsh session history
zsh/.zsh_history
zsh/.zsh_sessions/

# Vim history
vim/.viminfo

# macOS
.DS_Store
**/.DS_Store

# Spicetify user-specific cache
spicetify/CustomApps/marketplace-dist.zip

# Zsh compiled bytecode cache
**/*.zwc

# Matplotlib font/style cache (contains machine-specific absolute paths)
matplotlib/

# Third-party plugins (keep folders, ignore contents)
# These are installed by plugin managers at runtime
zi/plugins/*
!zi/plugins/.gitkeep
tmux/plugins/*
!tmux/plugins/.gitkeep
vim/.vim/plugged/*
!vim/.vim/plugged/.gitkeep
bundle/cache
.zcompdump

#!/usr/bin/env python3
# Manages the Catppuccin Mocha theme patch for the Claude Code binary.
# Replaces the "light-daltonized" theme slot with "catppuccin-mocha".
# Safe to re-run after every Claude Code update.

import re
import shutil
import sys
from pathlib import Path

# ---------------------------------------------------------------------------
# Helpers
# ---------------------------------------------------------------------------

RESET  = "\033[0m"
BOLD   = "\033[1m"
RED    = "\033[31m"
GREEN  = "\033[32m"
YELLOW = "\033[33m"
CYAN   = "\033[36m"
DIM    = "\033[2m"


def log(tag: str, color: str, msg: str) -> None:
    print(f"{color}{BOLD}{tag:>12}{RESET} {msg}")


def die(msg: str) -> None:
    log("error", RED, msg)
    sys.exit(1)


def usage() -> None:
    print(f"""
{BOLD}claude-theme{RESET} — Catppuccin Mocha theme manager for Claude Code

{BOLD}USAGE{RESET}
    claude-theme {CYAN}--apply-patch{RESET}   inject Catppuccin Mocha into the binary
    claude-theme {CYAN}--restore{RESET}       restore original binary from backup
    claude-theme {CYAN}--status{RESET}        show whether the patch is applied
    claude-theme {CYAN}--help{RESET}          show this message

{BOLD}NOTES{RESET}
    Re-run {CYAN}--apply-patch{RESET} after every Claude Code update.
    The first run creates a {DIM}claude.bak{RESET} backup next to the binary.
    The patch replaces the "light-daltonized" theme slot; that slot is
    sacrificed so no binary shifting is required.
""")


# ---------------------------------------------------------------------------
# Catppuccin Mocha palette  (all values use #RRGGBB — exactly 7 chars each)
# The rebuilt palette is shorter than the original; the gap is filled with
# space-padding before the closing '}' which is valid in minified JS.
# ---------------------------------------------------------------------------

MOCHA: dict[str, str] = {
    "autoAccept":                              "#cba6f7",   # mauve
    "bashBorder":                              "#f5c2e7",   # pink
    "claude":                                  "#fab387",   # peach

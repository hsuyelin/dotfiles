    "rainbow_yellow":                          "#f9e2af",   # yellow
    "rainbow_green":                           "#a6e3a1",   # green
    "rainbow_blue":                            "#89b4fa",   # blue
    "rainbow_indigo":                          "#b4befe",   # lavender
    "rainbow_violet":                          "#cba6f7",   # mauve
    "rainbow_red_shimmer":                     "#eba0ac",   # maroon
    "rainbow_orange_shimmer":                  "#f2cdcd",   # flamingo
    "rainbow_yellow_shimmer":                  "#f5e0dc",   # rosewater
    "rainbow_green_shimmer":                   "#a6e3a1",   # green lighter
    "rainbow_blue_shimmer":                    "#89dceb",   # sky
    "rainbow_indigo_shimmer":                  "#b4befe",   # lavender lighter
    "rainbow_violet_shimmer":                  "#cba6f7",   # mauve lighter
}

ORIGINAL_LABEL    = "Light mode (colorblind-friendly)"   # 32 chars
REPLACEMENT_LABEL = "Catppuccin Mocha (dark palette) "   # 32 chars — trailing space
assert len(ORIGINAL_LABEL) == len(REPLACEMENT_LABEL)

# ---------------------------------------------------------------------------
# Binary search anchors  (content-based, version-agnostic)
# ---------------------------------------------------------------------------

THEME_ARRAY_ANCHOR  = b'"dark","light","light-daltonized","dark-daltonized","light-ansi","dark-ansi"'
THEME_ARRAY_PATCHED = b'"dark","light","catppuccin-mocha","dark-daltonized","light-ansi","dark-ansi"'
PALETTE_ANCHOR      = b'autoAccept:"rgb(135,0,255)",bashBorder:"rgb(0,102,204)"'
OLD_THEME_NAME      = b"light-daltonized"
NEW_THEME_NAME      = b"catppuccin-mocha"
INCLUDES_PATTERN    = rb'\["light","light-daltonized","light-ansi"\]'
MOCHA_SIGNATURE     = b'"catppuccin-mocha"'


# ---------------------------------------------------------------------------
# Palette helpers
# ---------------------------------------------------------------------------

def build_palette(original_bytes: bytes) -> bytes:
    original_text = original_bytes.decode("utf-8")
    keys_ordered = re.findall(
        r'(\w+):"(?:rgb\([^"]+\)|#[0-9a-fA-F]+)"', original_text
    )
    if not keys_ordered:
        die("could not parse keys from palette object")

    inner_parts: list[str] = []
    for key in keys_ordered:
        if key not in MOCHA:
            die(f"palette key '{key}' not in MOCHA mapping — update the script")
        inner_parts.append(f'{key}:"{MOCHA[key]}"')

    prefix_match = re.match(r'^(\w+54=)', original_text)
    if not prefix_match:
        die("palette object does not match expected VARxx54= pattern")
    var_prefix = prefix_match.group(1)

    inner   = ",".join(inner_parts)
    rebuilt = f"{var_prefix}{{{inner}}}"

    target_len = len(original_bytes)
    delta = target_len - len(rebuilt)
    if delta < 0:
        die(
            f"rebuilt palette is {-delta} bytes longer than original "
            f"({len(rebuilt)} vs {target_len}) — binary structure has changed, "
            f"update MOCHA values to be shorter"
        )

    rebuilt = rebuilt[:-1] + (" " * delta) + "}"
    result  = rebuilt.encode("utf-8")
    assert len(result) == target_len
    return result


def extract_palette(data: bytes, anchor_start: int) -> tuple[int, bytes]:
    i = anchor_start
    while i < len(data) and data[i:i+1] != b"{":
        i += 1
    depth = 0
    while i < len(data):
        ch = data[i:i+1]
        if ch == b"{":
            depth += 1
        elif ch == b"}":
            depth -= 1
            if depth == 0:
                return anchor_start, data[anchor_start:i + 1]
        i += 1
    die("could not find closing '}' for palette object")


def find_palette_starts(data: bytes) -> list[int]:
    positions: list[int] = []
    search_from = 0
    while True:
        pos = data.find(PALETTE_ANCHOR, search_from)
        if pos == -1:
            break
        back      = max(0, pos - 8)
        brace_pos = data.find(b"{", pos)
        var_start = brace_pos - 1
        while var_start > back and data[var_start:var_start+1] not in (b",", b";", b"}"):
            var_start -= 1
        var_start += 1
        positions.append(var_start)
        search_from = pos + 1
    return positions


# ---------------------------------------------------------------------------
# Resolve binary path
# ---------------------------------------------------------------------------

def resolve_binary() -> Path:
    path_str = shutil.which("claude")
    if not path_str:
        die("'claude' not found in PATH")
    return Path(path_str).resolve()


# ---------------------------------------------------------------------------
# Commands
# ---------------------------------------------------------------------------

def cmd_status() -> None:
    claude_bin = resolve_binary()
    log("binary", CYAN, str(claude_bin))

    data = claude_bin.read_bytes()
    backup = claude_bin.with_suffix(".bak")

    if data.count(MOCHA_SIGNATURE) > 0:
        log("status", GREEN, "patch APPLIED — catppuccin-mocha theme is active")
    else:
        log("status", YELLOW, "patch NOT applied — original binary")

    if backup.exists():
        log("backup", CYAN, f"backup present: {backup}")
    else:
        log("backup", DIM, "no backup found")


def cmd_restore() -> None:
    claude_bin = resolve_binary()
    backup     = claude_bin.with_suffix(".bak")

    if not backup.exists():
        die(f"no backup found at {backup}")

    log("found", CYAN, str(claude_bin))
    shutil.copy2(backup, claude_bin)
    log("restored", GREEN, f"original binary restored from {backup}")
    log("note", DIM, "run --apply-patch again after the next Claude Code update")


def cmd_apply_patch() -> None:
    claude_bin = resolve_binary()
    log("found", CYAN, str(claude_bin))

    data = claude_bin.read_bytes()
    log("loaded", CYAN, f"{len(data):,} bytes")

    # Already patched?
    if data.count(MOCHA_SIGNATURE) > 0:
        log("info", YELLOW, "patch already applied — nothing to do")
        log("tip", DIM, "run --restore first if you want to re-apply a fresh patch")
        return

    # ------------------------------------------------------------------
    log("validate", YELLOW, "checking binary structure …")

    theme_count = data.count(THEME_ARRAY_ANCHOR)
    if theme_count == 0:
        die(
            "theme array anchor not found — binary structure has changed\n"
            "             expected: " + THEME_ARRAY_ANCHOR.decode()
        )
    log("ok", GREEN, f"theme array anchor found ({theme_count}×)")

    palette_starts = find_palette_starts(data)
    if not palette_starts:
        die("light-daltonized palette anchor not found — binary structure has changed")
    log("ok", GREEN, f"palette anchor found ({len(palette_starts)}×)")

    all_pos = [m.start() for m in re.finditer(re.escape(OLD_THEME_NAME), data)]
    if not all_pos:
        die("'light-daltonized' not found — theme may already be patched")

    includes_pos: set[int] = set()
    for m in re.finditer(INCLUDES_PATTERN, data):
        inner = data.find(OLD_THEME_NAME, m.start(), m.end())
        if inner != -1:
            includes_pos.add(inner)

    replace_pos = [p for p in all_pos if p not in includes_pos]
    skip_pos    = [p for p in all_pos if p in includes_pos]
    log("ok", GREEN,
        f"'light-daltonized': {len(all_pos)} total, "
        f"{len(replace_pos)} to replace, "
        f"{len(skip_pos)} skipped (includes-array)")

    palette_ops: list[tuple[int, bytes, bytes]] = []
    for pstart in palette_starts:
        _, orig = extract_palette(data, pstart)
        palette_ops.append((pstart, orig, build_palette(orig)))
    log("ok", GREEN,
        f"palette replacement built ({len(palette_ops)}×, "
        f"{len(palette_ops[0][1])} bytes each)")

    # ------------------------------------------------------------------
    backup = claude_bin.with_suffix(".bak")
    if not backup.exists():
        shutil.copy2(claude_bin, backup)
        log("backup", CYAN, f"created {backup}")
    else:
        log("backup", YELLOW, f"existing backup kept: {backup}")

    # ------------------------------------------------------------------
    patched = bytearray(data)

    for (pstart, orig, new) in sorted(palette_ops, reverse=True):
        patched[pstart:pstart + len(orig)] = new
    log("patched", GREEN, f"palette objects replaced ({len(palette_ops)}×)")

    patched_bytes = bytes(patched)
    all_pos2 = [m.start() for m in re.finditer(re.escape(OLD_THEME_NAME), patched_bytes)]
    inc_pos2: set[int] = set()
    for m in re.finditer(INCLUDES_PATTERN, patched_bytes):
        inner = patched_bytes.find(OLD_THEME_NAME, m.start(), m.end())
        if inner != -1:
            inc_pos2.add(inner)

    for pos in sorted([p for p in all_pos2 if p not in inc_pos2], reverse=True):
        patched[pos:pos + len(OLD_THEME_NAME)] = NEW_THEME_NAME
    log("patched", GREEN, f"theme name replaced ({len(all_pos2) - len(inc_pos2)}×)")

    old_lbl = ORIGINAL_LABEL.encode()
    new_lbl = REPLACEMENT_LABEL.encode()
    src = bytes(patched)
    lbl_count = src.count(old_lbl)
    if lbl_count:
        patched = bytearray(src.replace(old_lbl, new_lbl))
        log("patched", GREEN, f"display label replaced ({lbl_count}×)")
    else:
        log("warning", YELLOW, "display label not found (skipped)")

    claude_bin.write_bytes(bytes(patched))
    log("done", GREEN,
        "catppuccin-mocha theme applied — select it with /theme in Claude Code")


# ---------------------------------------------------------------------------
# Entry point
# ---------------------------------------------------------------------------

COMMANDS: dict[str, str] = {
    "--apply-patch": "inject Catppuccin Mocha into the Claude Code binary",
    "--restore":     "restore the original binary from backup",
    "--status":      "show whether the patch is currently applied",
    "--help":        "show this help message",
}


def main() -> None:
    args = sys.argv[1:]
    if not args or args[0] in ("--help", "-h"):
        usage()
        return

    cmd = args[0]
    if cmd == "--apply-patch":
        cmd_apply_patch()
    elif cmd == "--restore":
        cmd_restore()
    elif cmd == "--status":
        cmd_status()
    else:
        log("error", RED, f"unknown option: {cmd}")
        usage()
        sys.exit(1)


if __name__ == "__main__":
    main()

        { "type": "row", "key": "<tab>",       "en": "smart fold: container line → toggle all members; func line → toggle func body; else → za", "zh": "智能折叠：容器行→toggle所有成员；函数行→toggle函数体；其他→za" },
        { "type": "row", "key": "<space>za",   "en": "fold all function bodies in buffer (show structure)",       "zh": "折叠全文件所有函数体（显示结构）" },
        { "type": "row", "key": "<space>zz",   "en": "toggle all: zM (fold everything) ↔ zR (expand everything)","zh": "全折叠/全展开 toggle（代码很长时用）" },
        { "type": "row", "key": "za",          "en": "toggle fold open/closed",                                   "zh": "切换折叠开/关" },
        { "type": "row", "key": "zo / zc",     "en": "open / close fold",                                         "zh": "打开 / 关闭折叠" },
        { "type": "row", "key": "zO / zC",     "en": "recursively open / close fold",                            "zh": "递归打开 / 关闭折叠" },
        { "type": "row", "key": "zR / zM",     "en": "unfold / fold all (vim native)",                           "zh": "展开 / 折叠全部（vim 原生）" },
        { "type": "row", "key": "zj / zk",     "en": "jump to next / previous fold",                             "zh": "跳到下一个 / 上一个折叠" },
        { "type": "row", "key": "[z / ]z",     "en": "jump to start / end of current fold",                      "zh": "跳到当前折叠的起点 / 终点" }
      ]
    },
    {

        { "type": "row", "key": "jk",             "en": "[INSERT] exit insert mode (alias for <Esc>)",  "zh": "[插入] 退出插入模式（<Esc> 别名）" },
        { "type": "row", "key": "<C-h/j/k/l>",    "en": "navigate between splits (smart-splits)",       "zh": "在分割窗口间导航（smart-splits）" },
        { "type": "row", "key": "<C-f>",           "en": "find files (Telescope)",                       "zh": "查找文件（Telescope）" },
        { "type": "row", "key": "<C-b>",           "en": "buffer picker (Telescope)",                    "zh": "buffer 选择器（Telescope）" },
        { "type": "row", "key": "<C-c>",           "en": "close current buffer",                         "zh": "关闭当前 buffer" },
        { "type": "row", "key": "{ / }",           "en": "previous / next buffer tab",                   "zh": "上 / 下一个 buffer 标签" },
        { "type": "row", "key": "<C-[> / <C-]>",   "en": "previous / next vim tab",                      "zh": "上 / 下一个 vim 标签" },
        { "type": "row", "key": "<C-i>",           "en": "jump forward in jump list",                    "zh": "在跳转列表中向前跳转" },
        { "type": "row", "key": "<C-e>",           "en": "[INSERT] open emoji picker",                   "zh": "[插入] 打开 emoji 选择器" }
      ]
    },
    {

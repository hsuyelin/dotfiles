        { "type": "row", "key": "m,",    "en": "set next available mark on current line",    "zh": "在当前行设置下一个可用标记" },
        { "type": "row", "key": "m;",    "en": "toggle mark on current line",                "zh": "在当前行切换标记" },
        { "type": "row", "key": "m] / m[","en": "jump to next / previous mark",              "zh": "跳到下一个 / 上一个标记" },
        { "type": "row", "key": "m:",    "en": "preview mark in floating window",            "zh": "在浮动窗口预览标记" },
        { "type": "row", "key": "dm-",   "en": "delete all marks in current buffer",         "zh": "删除当前 buffer 的所有标记" }

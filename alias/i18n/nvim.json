        { "type": "row", "key": "yss{char}",        "en": "add surrounding around current line",         "zh": "为当前行添加包围符" },
        { "type": "row", "key": "ds{char}",         "en": "delete surrounding  e.g. ds( removes parens", "zh": "删除包围符，如 ds( 删除括号" },

      "entries": [
        { "type": "row", "key": "r",    "en": "flash jump — type 2-char label to teleport cursor", "zh": "Flash 跳转 — 输入 2 字符标签直达目标" },
        { "type": "row", "key": "R",    "en": "flash treesitter — jump by treesitter node",        "zh": "Flash treesitter — 按节点跳转" },
        { "type": "row", "key": "<C-r>","en": "flash treesitter — highlight entire syntax tree",  "zh": "Flash treesitter — 高亮整个语法树" }
      ]
    },
    {
      "id": "mini-move",
      "title": { "en": "mini.move  (move code blocks)", "zh": "mini.move（移动代码块）" },
      "entries": [
        { "type": "row", "key": "<M-h/j/k/l>", "en": "[VISUAL] move selection left / down / up / right",      "zh": "[可视] 向左/下/上/右移动选区" },
        { "type": "row", "key": "<M-h/j/k/l>", "en": "[NORMAL] move current line left / down / up / right",   "zh": "[普通] 向左/下/上/右移动当前行" }
      ]
    },
    {
      "id": "surround",
      "title": { "en": "Surround  (nvim-surround)", "zh": "包围符（nvim-surround）" },
